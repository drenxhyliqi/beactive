# Copy to .env.local for local development (and set in the Vercel dashboard for production).

# Public site URL — used for Open Graph / canonical metadata.
# In production on Vercel this is auto-derived from VERCEL_URL if left unset.
NEXT_PUBLIC_SITE_URL=https://beactive.co

# Base URL of the FastAPI backend. Defaults to http://localhost:8000 when unset.
# The backend is not wired up yet, so this is optional for the landing site.
NEXT_PUBLIC_API_URL=http://localhost:8000
